{
  "name": "aqshara-app",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @aqshara/web dev",
    "dev:api": "pnpm --filter @aqshara/api dev",
    "dev:worker": "cd apps/worker && uv run uvicorn worker.app:create_app --factory --host 0.0.0.0 --port 8100 --reload",
    "lint": "turbo run lint --filter=!web",
    "lint:worker": "cd apps/worker && uv run ruff check src tests",
    "test": "turbo run test --filter=!web",
    "test:worker": "cd apps/worker && uv run pytest -q",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "check-types:worker": "cd apps/worker && uv run mypy src",
    "start:worker": "cd apps/worker && uv run python -m worker",
    "spec:generate": "pnpm --filter @aqshara/api spec:generate",
    "client:generate": "pnpm --filter @aqshara/api-client generate",
    "client:check": "pnpm --filter @aqshara/api-client check",
    "db:generate": "pnpm --filter @aqshara/database db:generate",
    "db:migrate": "pnpm --filter @aqshara/database db:migrate",
    "db:push": "pnpm --filter @aqshara/database db:push",
    "db:studio": "pnpm --filter @aqshara/database db:studio"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "prettier": "^3.7.4",
    "turbo": "^2.8.20",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
