{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalDependencies": [".env*", "**/.env*"],
  "globalEnv": [
    "API_BASE_URL",
    "NEXT_PUBLIC_API_BASE_URL",
    "CLERK_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
    "CLERK_SECRET_KEY",
    "REDIS_HOST",
    "REDIS_PORT",
    "DATABASE_URL",
    "API_PORT",
    "OPENAI_API_KEY",
    "OPENAI_URL",
    "OPENAI_MODEL",
    "AQSHARA_LOG_FORMAT",
    "AQSHARA_EXPORTS_DIR",
    "AQSHARA_SOURCES_DIR",
    "R2_ACCOUNT_ID",
    "R2_ACCESS_KEY_ID",
    "R2_SECRET_ACCESS_KEY",
    "R2_BUCKET",
    "MISTRAL_API_KEY",
    "MISTRAL_API_BASE_URL",
    "WORKER_RECOVERY_STALE_MS",
    "MISTRAL_OCR_TIMEOUT_MS",
    "WORKER_PROXY_BASE_URL",
    "WORKER_PROXY_TOKEN",
    "WORKER_PUBLIC_BASE_URL",
    "WORKER_PROXY_TIMEOUT_MS",
    "WORKER_PROXY_SYNC_ENABLED",
    "WORKER_EXPORT_CONCURRENCY",
    "WORKER_SOURCE_CONCURRENCY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**",
        "apps/api/openapi/openapi.json",
        "src/generated/**"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": []
    },
    "spec:generate": {
      "dependsOn": ["^build"],
      "outputs": ["apps/api/openapi/openapi.json"]
    },
    "generate": {
      "dependsOn": ["^generate", "^spec:generate"],
      "outputs": ["src/generated/**"]
    },
    "check": {
      "dependsOn": ["^check"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
