{
  "name": "@aqshara/api",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "rm -rf dist && tsc -p tsconfig.json && node --test \"dist/src/**/*.test.js\"",
    "spec:generate": "tsc -p tsconfig.json && node dist/scripts/generate-openapi.js",
    "clerk:backfill": "tsc -p tsconfig.json && node dist/scripts/backfill-clerk-users.js",
    "smoke:readiness": "tsx scripts/smoke-readiness.ts",
    "smoke:providers": "tsx scripts/smoke-providers.ts",
    "smoke:exports": "tsx scripts/smoke-exports.ts"
  },
  "dependencies": {
    "@aqshara/api-spec": "workspace:*",
    "@aqshara/config": "workspace:*",
    "@aqshara/database": "workspace:^",
    "@aqshara/documents": "workspace:^",
    "@aqshara/observability": "workspace:*",
    "@aqshara/queue": "workspace:*",
    "@aqshara/storage": "workspace:*",
    "bullmq": "^5.63.0",
    "@clerk/backend": "^3.2.2",
    "@hono/clerk-auth": "^3.1.0",
    "@hono/node-server": "^1.19.6",
    "@hono/swagger-ui": "^0.5.2",
    "@hono/zod-openapi": "^1.1.5",
    "@hono/zod-validator": "^0.7.6",
    "@scalar/hono-api-reference": "^0.10.4",
    "@scalar/openapi-to-markdown": "^0.4.13",
    "drizzle-orm": "^0.44.6",
    "hono": "^4.10.4",
    "openai": "^6.33.0",
    "pdfjs-dist": "^4.10.38"
  },
  "devDependencies": {
    "@aqshara/eslint-config": "workspace:*",
    "@aqshara/typescript-config": "workspace:*",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.2"
  }
}
