{
  "name": "@aqshara/api",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "node --watch --experimental-strip-types src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "tsc -p tsconfig.json && node --test dist/src/app.test.js",
    "spec:generate": "tsc -p tsconfig.json && node dist/scripts/generate-openapi.js"
  },
  "dependencies": {
    "@aqshara/api-spec": "workspace:*",
    "@aqshara/config": "workspace:*",
    "@aqshara/observability": "workspace:*",
    "@hono/node-server": "^1.19.6",
    "@hono/swagger-ui": "^0.5.2",
    "@hono/zod-openapi": "^1.1.5",
    "hono": "^4.10.4"
  },
  "devDependencies": {
    "@aqshara/eslint-config": "workspace:*",
    "@aqshara/typescript-config": "workspace:*",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "typescript": "5.9.2"
  }
}
