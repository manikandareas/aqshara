API_PORT=9000
API_BASE_URL=http://localhost:9000
NEXT_PUBLIC_API_BASE_URL=http://localhost:9000
CLERK_SECRET_KEY=sk_test_your_secret_key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_WEBHOOK_SIGNING_SECRET=whsec_your_webhook_signing_secret
DATABASE_URL=postgres://postgres:postgres@localhost:5432/aqshara
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Required for real AI provider; without this API falls back to FakeAiProvider.
OPENAI_API_KEY=
# Optional OpenAI overrides.
OPENAI_URL=
OPENAI_MODEL=gpt-4o-mini
# Optional local filesystem overrides when R2 is not configured.
AQSHARA_EXPORTS_DIR=
AQSHARA_SOURCES_DIR=
# Required in production for object storage-backed exports/sources.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Optional OCR support for source parsing; if set, R2 should also be configured.
MISTRAL_API_KEY=
MISTRAL_API_BASE_URL=https://api.mistral.ai
# Optional: set to "json" for structured production logs
AQSHARA_LOG_FORMAT=
