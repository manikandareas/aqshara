{
  "name": "@aqshara/worker",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "node --watch --experimental-strip-types src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "rm -rf dist && tsc -p tsconfig.json && node --test \"dist/**/*.test.js\""
  },
  "dependencies": {
    "@aqshara/config": "workspace:*",
    "@aqshara/database": "workspace:*",
    "@aqshara/documents": "workspace:*",
    "@aqshara/observability": "workspace:*",
    "@aqshara/queue": "workspace:*",
    "@aqshara/storage": "workspace:*",
    "bullmq": "^5.63.0",
    "docx": "^9.5.1",
    "drizzle-orm": "^0.44.6",
    "pdfjs-dist": "^4.10.38"
  },
  "devDependencies": {
    "@aqshara/eslint-config": "workspace:*",
    "@aqshara/typescript-config": "workspace:*",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "typescript": "5.9.2"
  }
}
