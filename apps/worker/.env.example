REDIS_HOST=127.0.0.1
REDIS_PORT=6379
DATABASE_URL=postgresql://user:pass@localhost:5432/aqshara
# Optional: where DOCX files are written (default: <cwd>/.data/exports)
AQSHARA_EXPORTS_DIR=
# Optional: where source artifacts are written in local dev / tests (default: <cwd>/.data/sources)
AQSHARA_SOURCES_DIR=
# Required in production for export/source storage; do not rely on local fallback there.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Optional OCR support for source parsing beta; if set, R2 must also be configured.
MISTRAL_API_KEY=
MISTRAL_API_BASE_URL=https://api.mistral.ai
# Optional OCR timeout in milliseconds.
MISTRAL_OCR_TIMEOUT_MS=45000
# Optional recovery sweep threshold in milliseconds.
WORKER_RECOVERY_STALE_MS=900000
# Optional: set to "json" for structured production logs
AQSHARA_LOG_FORMAT=json
