# Runtime
NODE_ENV=development
AQSHARA_LOG_FORMAT=json

# Core dependencies
DATABASE_URL=postgres://postgres:postgres@localhost:5432/aqshara
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Local storage fallback
AQSHARA_EXPORTS_DIR=.data/exports
AQSHARA_SOURCES_DIR=.data/sources

# Worker runtime
WORKER_RECOVERY_STALE_MS=900000
MISTRAL_OCR_TIMEOUT_MS=45000
WORKER_EXPORT_CONCURRENCY=4
WORKER_SOURCE_CONCURRENCY=2

# BullMQ Proxy
WORKER_PROXY_BASE_URL=http://localhost:8080
WORKER_PUBLIC_BASE_URL=http://localhost:8100
WORKER_PROXY_TIMEOUT_MS=60000
WORKER_PROXY_SYNC_ENABLED=true
WORKER_PROXY_TOKEN=dev-token

# R2 object storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Mistral OCR
MISTRAL_API_KEY=
MISTRAL_API_BASE_URL=https://api.mistral.ai
