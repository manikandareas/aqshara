# Shared runtime
NODE_ENV=development
LOG_LEVEL=info

# API server
PORT=3000
API_PREFIX=api/v1
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aqshara
DATABASE_URL_DIRECT=
REDIS_URL=redis://localhost:6379
QUEUE_DISABLED=false

# Queue names
DOCUMENT_PROCESS_QUEUE_NAME=document.process
DOCUMENT_PROCESS_RETRY_QUEUE_NAME=document.process.retry
DOCUMENT_PROCESS_DLQ_QUEUE_NAME=document.process.dlq
TRANSLATION_RETRY_QUEUE_NAME=translation.retry
TRANSLATION_RETRY_RETRY_QUEUE_NAME=translation.retry.retry
TRANSLATION_RETRY_DLQ_QUEUE_NAME=translation.retry.dlq
VIDEO_GENERATE_QUEUE_NAME=video.generate
VIDEO_GENERATE_RETRY_QUEUE_NAME=video.generate.retry
VIDEO_GENERATE_DLQ_QUEUE_NAME=video.generate.dlq

# AI providers
MISTRAL_API_KEY=replace-me
MISTRAL_OCR_MODEL=mistral-ocr-latest
MISTRAL_TIMEOUT_MS=60000
OPENAI_API_KEY=replace-me
OPENAI_TRANSLATION_MODEL=gpt-4.1
OPENAI_TRANSLATION_TIMEOUT_MS=60000
OPENAI_GLOSSARY_MODEL=gpt-4.1
OPENAI_GLOSSARY_TIMEOUT_MS=90000

# Object storage
R2_ENDPOINT=https://example.r2.cloudflarestorage.com
R2_REGION=auto
R2_ACCESS_KEY_ID=replace-me
R2_SECRET_ACCESS_KEY=replace-me
R2_BUCKET=aqshara-local
DOCUMENT_UPLOAD_MAX_BYTES=52428800
READINESS_CHECK_STORAGE=false

# Auth and billing
CLERK_SECRET_KEY=replace-me
CLERK_PUBLISHABLE_KEY=replace-me
CLERK_JWT_KEY=
CLERK_AUTHORIZED_PARTIES=http://localhost:3000
POLAR_ACCESS_TOKEN=replace-me
POLAR_WEBHOOK_SECRET=replace-me