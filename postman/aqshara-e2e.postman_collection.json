    "name": "Aqshara API E2E",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Stateful end-to-end sequence for Aqshara local API, Clerk auth, documents, AI, sources, exports, and cleanup."
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth & Webhook",
      "item": [
        {
          "name": "01. Clerk - Start Sign In",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{clerk_frontend_api_url}}/v1/client/sign_ins"
            },
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "identifier={{clerk_email}}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "[\"clerk_frontend_api_url\", \"clerk_email\", \"clerk_password\"].forEach(function (key) {",
                  "      var value = (pm.environment.get(key) || \"\").trim();",
                  "      if (!value) {",
                  "        throw new Error(key + \" environment variable is required\");",
                  "      }",
                  "    });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"clerk sign-in start returns success\", function () {",
                  "      pm.expect([200, 201]).to.include(pm.response.code);",
                  "    });",
                  "    var json = pm.response.json();",
                  "    var payload = json.response || json;",
                  "    var signInId = payload.id || \"\";",
                  "    pm.test(\"clerk sign-in id is present\", function () {",
                  "      pm.expect(signInId).to.not.eql(\"\");",
                  "    });",
                  "    pm.environment.set(\"clerk_sign_in_id\", signInId);"
                ]
              }
            }
          ]
        },
        {
          "name": "02. Clerk - Attempt Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{clerk_frontend_api_url}}/v1/client/sign_ins/{{clerk_sign_in_id}}/attempt_first_factor"
            },
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "strategy=password&password={{clerk_password}}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"clerk password attempt returns success\", function () {",
                  "      pm.expect([200, 201]).to.include(pm.response.code);",
                  "    });",
                  "    var json = pm.response.json();",
                  "    var payload = json.response || json;",
                  "    if (payload.status === \"needs_second_factor\") {",
                  "      throw new Error(\"This Postman suite assumes Clerk MFA is disabled for the test user\");",
                  "    }",
                  "    var sessionId = payload.created_session_id || payload.createdSessionId || \"\";",
                  "    pm.test(\"clerk returns a created_session_id\", function () {",
                  "      pm.expect(sessionId).to.not.eql(\"\");",
                  "    });",
                  "    pm.environment.set(\"clerk_session_id\", sessionId);"
                ]
              }
            }
          ]
        },
        {
          "name": "03. Clerk - Read Client Session",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{clerk_frontend_api_url}}/v1/client"
            },
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"clerk client returns success\", function () {",
                  "      pm.response.to.have.status(200);",
                  "    });",
                  "    var json = pm.response.json();",
                  "    var payload = json.response || json;",
                  "    var sessions = payload.sessions || [];",
                  "    var clerkSessionId = pm.environment.get(\"clerk_session_id\");",
                  "    var activeSession = sessions.find(function (entry) {",
                  "      return entry.id === clerkSessionId;",
                  "    }) || sessions[0];",
                  "    var accessToken = activeSession && activeSession.last_active_token",
                  "      ? (activeSession.last_active_token.jwt || \"\")",
                  "      : \"\";",
                  "    pm.test(\"clerk client exposes session jwt\", function () {",
                  "      pm.expect(accessToken).to.not.eql(\"\");",
                  "    });",
                  "    pm.environment.set(\"access_token\", accessToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "04. Webhook - Signed user.created",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/webhooks/clerk"
            },
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{{clerk_webhook_payload}}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var webhookUserId = (pm.environment.get(\"clerk_webhook_user_id\") || \"\").trim() || (\"postman_webhook_\" + Date.now());",
                  "    var webhookEmail = (pm.environment.get(\"clerk_webhook_email\") || \"\").trim() || \"postman-webhook@example.com\";",
                  "    var payload = JSON.stringify({",
                  "      type: \"user.created\",",
                  "      data: {",
                  "        id: webhookUserId,",
                  "        primary_email_address_id: webhookUserId + \"_primary_email\",",
                  "        email_addresses: [",
                  "          {",
                  "            id: webhookUserId + \"_primary_email\",",
                  "            email_address: webhookEmail",
                  "          }",
                  "        ],",
                  "        first_name: \"Postman\",",
                  "        last_name: \"Webhook\",",
                  "        username: null,",
                  "        image_url: null",
                  "      }",
                  "    });",
                  "    var secret = (pm.environment.get(\"clerk_webhook_signing_secret\") || \"\").trim();",
                  "    if (!secret) {",
                  "      throw new Error(\"clerk_webhook_signing_secret environment variable is required\");",
                  "    }",
                  "    var messageId = \"msg_\" + Date.now();",
                  "    var timestamp = String(Math.floor(Date.now() / 1000));",
                  "    var normalizedSecret = secret.replace(/^whsec_/, \"\");",
                  "    var key = CryptoJS.enc.Base64.parse(normalizedSecret);",
                  "    var signedContent = messageId + \".\" + timestamp + \".\" + payload;",
                  "    var signature = CryptoJS.enc.Base64.stringify(CryptoJS.HmacSHA256(signedContent, key));",
                  "    pm.environment.set(\"clerk_webhook_payload\", payload);",
                  "    pm.request.headers.upsert({ key: \"svix-id\", value: messageId });",
                  "    pm.request.headers.upsert({ key: \"svix-timestamp\", value: timestamp });",
                  "    pm.request.headers.upsert({ key: \"svix-signature\", value: \"v1,\" + signature });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"signed webhook returns 200\", function () {",
                  "      pm.response.to.have.status(200);",
                  "    });"
                ]
              }
            }
          ]
        },
        {
          "name": "05. Webhook - Invalid Signature",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/webhooks/clerk"
            },
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{{clerk_webhook_payload}}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.request.headers.upsert({ key: \"svix-id\", value: \"invalid_\" + Date.now() });",
                  "    pm.request.headers.upsert({ key: \"svix-timestamp\", value: String(Math.floor(Date.now() / 1000)) });",
                  "    pm.request.headers.upsert({ key: \"svix-signature\", value: \"v1,invalid\" });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"invalid webhook returns 400\", function () {",
                  "      pm.response.to.have.status(400);",
                  "    });"
                ]
              }
            }
          ]
        },
